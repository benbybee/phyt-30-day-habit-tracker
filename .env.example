# =============================================================================
# Phyt Habit Tracker — environment variables
# Copy this file to `.env.local` and fill in the real values.
# Never commit `.env.local` (it's gitignored).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — auth + database
# Get these from your Supabase dashboard: Project Settings → API
# -----------------------------------------------------------------------------

# Public project URL (e.g. https://abcdefghijklmnop.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (the long eyJ... string). Safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only, NEVER expose to the browser.
# Used for privileged reads in the /admin dashboard and for inserting
# contacts during signup.
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection string (used for running SQL migrations).
# Get from: Project Settings → Database → Connection string (URI).
DATABASE_URL=

# -----------------------------------------------------------------------------
# Admin dashboard
# -----------------------------------------------------------------------------

# Comma-separated list of email addresses that can access /admin.
# Case-insensitive. Sign in with one of these addresses via the regular login
# flow, then navigate to /admin.
# e.g. ben@balanceofnature.com,jane@balanceofnature.com
ADMIN_EMAILS=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# Base URL used in magic-link redirects. Set per-environment:
#   local      → http://localhost:3000
#   preview    → https://phyt-30-day-habit-tracker.vercel.app
#   production → https://track.balanceofnature.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
