# =============================================================================
# Phyt Habit Tracker — environment variables
# Copy this file to `.env.local` and fill in the real values.
# Never commit `.env.local` (it's gitignored).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — auth + database
# Get these from your Supabase dashboard: Project Settings → API
# -----------------------------------------------------------------------------

# Public project URL (e.g. https://abcdefghijklmnop.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (the long eyJ... string). Safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only, NEVER expose to the browser.
# Used for privileged operations like inserting into contacts table from API routes.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Resend — transactional email (new-signup notifications to BoN)
# Get these from your Resend dashboard: https://resend.com
# -----------------------------------------------------------------------------

# Resend API key (starts with re_...)
RESEND_API_KEY=

# Verified sender email — must be on a domain you've verified in Resend.
# e.g. notifications@balanceofnature.com or noreply@track.balanceofnature.com
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# Balance of Nature — destination for new-signup notification emails
# -----------------------------------------------------------------------------

# The BoN team email that receives new contact notifications.
# Can be a single address or comma-separated list (e.g. sales@bon.com,leads@bon.com)
BON_NOTIFICATION_EMAIL=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# Base URL used in magic-link redirects. Set per-environment:
#   local      → http://localhost:3000
#   preview    → https://phyt-30-day-habit-tracker.vercel.app
#   production → https://track.balanceofnature.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
